<?xml version="1.0" encoding="utf-8"?>
<!--
  Phone layout: CoordinatorLayout with BottomNavigationView and FragmentContainerView.
  Tablet layout (sw600dp) uses NavigationRail instead — see res/layout-sw600dp/.
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.LIMESettings">

    <!-- Main fragment container — fills space above the bottom nav -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/main_fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Bottom navigation — phone only -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/main_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:paddingBottomSystemWindowInsets="true"
        app:menu="@menu/main_nav" />

    <!-- Activity-scoped progress overlay — persists across fragment switches -->
    <FrameLayout
        android:id="@+id/activity_progress_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:background="#66000000">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_gravity="center">

            <TextView
                android:id="@+id/activity_progress_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                tools:text="Loading..."
                android:textColor="#FFFFFF" />

            <ProgressBar
                android:id="@+id/activity_progress_bar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
