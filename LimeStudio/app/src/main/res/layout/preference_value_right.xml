<?xml version="1.0" encoding="utf-8"?>
<!--
  iOS-style preference row: title on the left, currently-selected value on the
  right (in secondary text color). Used for the per-IM reverse-lookup ListPreferences
  in xml/preference.xml > reverse_lookup_screen so each row matches the SwiftUI
  Picker(.menu) layout on iOS.

  Framework auto-binds these two IDs:
    @android:id/title    populated from android:title (the IM name)
    @android:id/summary  populated by the SimpleSummaryProvider (the selected lookup source)
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="?android:attr/listPreferredItemHeightSmall"
    android:orientation="horizontal"
    android:paddingStart="?android:attr/listPreferredItemPaddingStart"
    android:paddingEnd="?android:attr/listPreferredItemPaddingEnd"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- Title and value each take a weighted share and WRAP (multi-line) instead of
         clipping, so both always show in full at any font size. -->
    <TextView
        android:id="@android:id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="3"
        android:textAppearance="@style/LIME.Body"
        android:maxLines="3"
        android:ellipsize="end" />

    <TextView
        android:id="@android:id/summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="2"
        android:layout_marginStart="8dp"
        android:textAppearance="@style/LIME.Body"
        android:textColor="?android:attr/textColorSecondary"
        android:gravity="end"
        android:maxLines="3" />

</LinearLayout>
