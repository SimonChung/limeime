<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/setup_scroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="24dp"
        android:paddingBottom="24dp">

        <!-- Brand Block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:src="@drawable/logo"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="萊姆輸入法"
                android:textAppearance="@style/LIME.TabTitle"
                android:layout_marginStart="16dp" />

        </LinearLayout>

        <!-- Status Card: neutral background; icon + text carry state color (iOS parity) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/statusCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/setup_status_bg"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/statusIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:contentDescription="@null"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAppearance="@style/LIME.Subheadline" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Setup heading + step descriptions (restored from prior Android implementation) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/setupHeading"
            android:textAppearance="@style/LIME.Title1"
            android:text="@string/setup_im_system_settings"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/setupStep1Description"
            android:textAppearance="@style/LIME.Subheadline"
            android:text="@string/setup_im_system_settings_description"
            android:layout_marginBottom="5dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/setupStep2Description"
            android:textAppearance="@style/LIME.Subheadline"
            android:text="@string/setup_im_system_impicker_description"
            android:layout_marginBottom="16dp" />

        <!-- Button: System Settings -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSetupImSystemSetting"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_im_wizard_nextstep"
            android:layout_marginBottom="8dp" />

        <!-- Button: IM Picker — bordered (12% green tinted fill, no stroke) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSetupImSystemIMPicker"
            style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
            app:backgroundTint="@color/button_tint_primary"
            android:textColor="?attr/colorPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_im_system_selectLIME"
            android:layout_marginBottom="24dp" />

        <!-- Voice permission block: a tinted status BANNER (icon + title only),
             then the description and action button on the plain page background. -->
        <LinearLayout
            android:id="@+id/voicePermissionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="24dp">

            <!-- Tinted banner row (only this carries the status tint) -->
            <LinearLayout
                android:id="@+id/voicePermissionBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@color/status_tint_red"
                android:padding="12dp">

                <ImageView
                    android:id="@+id/voicePermissionIcon"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/sym_keyboard_voice_light"
                    android:contentDescription="@null"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/voicePermissionTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/setup_voice_permission_title"
                    android:textAppearance="@style/LIME.Subheadline" />

            </LinearLayout>

            <TextView
                android:id="@+id/voicePermissionDetail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_voice_permission_not_granted"
                android:textAppearance="@style/LIME.Subheadline"
                android:layout_marginTop="12dp"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp" />

            <!-- Bordered (12% green tinted fill, no stroke) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/voicePermissionButton"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                app:backgroundTint="@color/button_tint_primary"
                android:textColor="?attr/colorPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/setup_voice_permission_open_settings"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- About footer: full-bleed separator, three equal-width link chips
             (使用手冊 / 版權說明 / 原始碼) and a one-line copyright banner.
             Same IDs as before so SetupFragment's click handlers are unchanged;
             only the layout is re-laid-out to match the iOS About footer. -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="-16dp"
            android:layout_marginEnd="-16dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="16dp"
            android:background="?attr/colorControlHighlight" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- 使用手冊 chip -->
            <LinearLayout
                android:id="@+id/txtManualUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="5dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="15dp"
                android:paddingBottom="13dp"
                android:background="@drawable/bg_about_chip"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_menu_book_24"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/about_manual_label"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- 版權說明 chip -->
            <LinearLayout
                android:id="@+id/txtLicenseUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="15dp"
                android:paddingBottom="13dp"
                android:background="@drawable/bg_about_chip"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_description_24"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/about_license_link"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="14sp" />

            </LinearLayout>

            <!-- 原始碼 chip -->
            <LinearLayout
                android:id="@+id/txtGithubUrl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="5dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="15dp"
                android:paddingBottom="13dp"
                android:background="@drawable/bg_about_chip"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_code_24"
                    app:tint="?attr/colorPrimary"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:text="@string/about_source_label"
                    android:textColor="?attr/colorPrimary"
                    android:textSize="14sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- One-line copyright banner (txtVersion: set by SetupFragment) -->
        <TextView
            android:id="@+id/txtVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:textColor="?android:attr/textColorSecondary"
            android:textAppearance="@style/LIME.Footnote" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
