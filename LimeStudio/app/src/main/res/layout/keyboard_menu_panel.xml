<?xml version="1.0" encoding="utf-8"?>
<!--
  Custom content view for the long-press keyboard-key options menu. Replaces the
  plain AlertDialog item list so every entry is a styled row (keyboard_menu_row)
  and 簡繁轉換 hosts its 無/繁轉簡/簡轉繁 segmented control inline at the top level
  (no drill-down). Action rows are added programmatically into @id/menu_rows_top
  and @id/menu_rows_bottom around the han-convert block.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="vertical"
    android:scrollbarStyle="outsideOverlay"
    android:fadeScrollbars="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="4dp"
        android:paddingBottom="4dp">

        <!-- Rows above 簡繁轉換 (喜好設定 / 反查字根) -->
        <LinearLayout
            android:id="@+id/menu_rows_top"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- 簡繁轉換 — inline segmented control at the top level. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="20dp"
                    android:tint="?attr/colorPrimary"
                    android:src="@drawable/ic_swap_24"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/han_convert_option_list"
                    android:textAppearance="@style/LIME.Body" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/han_toggle_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="44dp"
                android:layout_marginTop="10dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/han_opt_none"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:maxLines="1"
                    android:text="@string/han_convert_none"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/han_opt_t2s"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:maxLines="1"
                    android:text="@string/han_convert_t2s"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/han_opt_s2t"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:maxLines="1"
                    android:text="@string/han_convert_s2t"
                    android:textAllCaps="false" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>

        <!-- Rows below 簡繁轉換 (切換鍵盤 / 系統輸入法 / 語音輸入) -->
        <LinearLayout
            android:id="@+id/menu_rows_bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <!-- 分離鍵盤 — inline segmented control (關閉 / 開啟 / 僅橫向開啟). Hidden when
             the split option is unavailable (landscape + arrow keys on). The choice
             is recorded here and applied to the keyboard on dismiss, not on tap. -->
        <LinearLayout
            android:id="@+id/menu_split_block"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginEnd="20dp"
                    android:tint="?attr/colorPrimary"
                    android:src="@drawable/ic_split_24"
                    android:contentDescription="@null" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/split_keyboard"
                    android:textAppearance="@style/LIME.Body" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/split_toggle_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="44dp"
                android:layout_marginTop="10dp"
                app:singleSelection="true"
                app:selectionRequired="true"
                xmlns:app="http://schemas.android.com/apk/res-auto">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/split_opt_off"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:maxLines="1"
                    android:text="@string/split_keyboard_off"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/split_opt_on"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:maxLines="1"
                    android:text="@string/split_keyboard_on"
                    android:textAllCaps="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/split_opt_landscape"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:paddingStart="2dp"
                    android:paddingEnd="2dp"
                    android:maxLines="1"
                    android:text="@string/split_keyboard_landscape"
                    android:textAllCaps="false" />

            </com.google.android.material.button.MaterialButtonToggleGroup>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
