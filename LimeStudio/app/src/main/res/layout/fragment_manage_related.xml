<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="net.toload.main.hd.ui.view.ManageRelatedFragment">

    <!-- Original content will go here -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/manage_related_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:titleTextColor="?android:attr/textColorPrimary"
            app:navigationIconTint="?android:attr/textColorSecondary" />

        <LinearLayout
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="4dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <TextView
                android:id="@+id/tv_related_label_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textAppearance="@style/LIME.Title1"
                android:textColor="?android:attr/textColorPrimary"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:text="@string/manage_related_title" />

            <EditText
                android:id="@+id/edtManageRelatedSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/manage_related_search"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:background="@drawable/search_bar_bg"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:id="@+id/gridManageRelated"
                android:clipToPadding="false" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/pagination_bar"
            android:orientation="horizontal"
            android:layout_height="wrap_content"
            android:layout_width="match_parent">

            <Button
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/manage_related_previous"
                android:id="@+id/btnManageRelatedPrevious"
                android:textColor="?attr/colorPrimary"
                android:textAllCaps="false"
                android:paddingRight="12dp"
                android:paddingLeft="12dp" />


            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:id="@+id/txtNavigationInfo"
                android:textAppearance="@style/LIME.Footnote"
                android:gravity="center_horizontal"
                android:layout_weight="1" />

            <Button
                style="?attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/manage_related_next"
                android:id="@+id/btnManageRelatedNext"
                android:textColor="?attr/colorPrimary"
                android:textAllCaps="false"
                android:paddingLeft="12dp"
                android:paddingRight="12dp" />

        </LinearLayout>

        <!-- Vpon
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/adLayout">

        </RelativeLayout>
        -->

    </LinearLayout>

    <ProgressBar
        android:id="@+id/loading_spinner"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</FrameLayout>
