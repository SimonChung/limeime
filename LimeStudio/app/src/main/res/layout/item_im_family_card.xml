<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header row: icon + title + installed badge + chevron -->
        <LinearLayout
            android:id="@+id/card_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:background="?attr/selectableItemBackground">

            <!-- Per-family badge: grey rounded-square + representative character,
                 matching the IM-list page (ㄅ 倉 速 易 行 拼 …). -->
            <FrameLayout
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_im_badge">

                <TextView
                    android:id="@+id/tv_family_badge"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textColor="@color/im_badge_foreground"
                    android:contentDescription="@null" />

                <ImageView
                    android:id="@+id/iv_family_badge"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    app:tint="@color/im_badge_foreground"
                    android:contentDescription="@null" />

            </FrameLayout>

            <TextView
                android:id="@+id/tv_im_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/LIME.Body"
                android:textStyle="bold" />

            <!-- Shown when installed; replaces chevron -->
            <TextView
                android:id="@+id/tv_installed_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/im_installed_badge"
                android:textAppearance="@style/LIME.Caption"
                android:textColor="?attr/colorPrimary"
                android:layout_marginEnd="4dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/iv_chevron"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="@null"
                app:tint="?attr/colorControlNormal" />

        </LinearLayout>

        <!-- Expandable body -->
        <LinearLayout
            android:id="@+id/body_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp"
            android:visibility="gone">

            <!-- Restore learning switch -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switch_restore_learning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="還原已學習記錄" />

            <!-- Dynamic cloud download rows injected here -->
            <LinearLayout
                android:id="@+id/cloud_buttons_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Import .limedb -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_import_limedb"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="匯入 .limedb"
                app:icon="@drawable/ic_archivebox"
                app:iconGravity="start"
                app:iconPadding="8dp" />

            <!-- Import .cin / .lime (hidden for RELATED) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_import_txt"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="匯入 .cin / .lime"
                android:visibility="gone"
                app:icon="@drawable/ic_list_bullet"
                app:iconGravity="start"
                app:iconPadding="8dp" />

            <!-- Import default related (visible only for RELATED) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_import_default_related"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/setup_im_import_related_default"
                android:visibility="gone"
                app:icon="@drawable/ic_list_bullet"
                app:iconGravity="start"
                app:iconPadding="8dp" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
