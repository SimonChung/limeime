<?xml version="1.0" encoding="utf-8"?>
<!--
  簡繁轉換 (han conversion) inline segmented control. A title row, an M3
  single-select MaterialButtonToggleGroup (無 / 繁轉簡 / 簡轉繁), and a footer.
  Backed by SegmentedHanPreference, which persists the existing
  han_convert_option int (0/1/2) — same key, values, and persistence as the
  ListPreference it replaces; only the presentation changes.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="?android:attr/listPreferredItemPaddingStart"
    android:paddingEnd="?android:attr/listPreferredItemPaddingEnd"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@+id/han_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/han_convert_option_list"
        android:textAppearance="@style/LIME.Body" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/han_toggle_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        app:singleSelection="true"
        app:selectionRequired="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/han_opt_none"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1"
            android:text="@string/han_convert_none"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/han_opt_t2s"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1"
            android:text="@string/han_convert_t2s"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/han_opt_s2t"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:minWidth="0dp"
            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingStart="2dp"
            android:paddingEnd="2dp"
            android:maxLines="1"
            android:text="@string/han_convert_s2t"
            android:textAllCaps="false" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/han_convert_footer"
        android:textAppearance="@style/LIME.Footnote"
        android:textColor="?android:attr/textColorSecondary" />

</LinearLayout>
