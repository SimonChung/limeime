<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/im_detail_toolbar"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:titleTextColor="?android:attr/textColorPrimary"
            app:navigationIconTint="?android:attr/textColorSecondary" />

        <!-- Trailing share button OVERLAY (outside MaterialToolbar so its click events aren't absorbed) -->
        <ImageButton
            android:id="@+id/btn_im_share"
            android:layout_width="?attr/actionBarSize"
            android:layout_height="?attr/actionBarSize"
            android:layout_gravity="end|center_vertical"
            android:src="@drawable/outline_share_24"
            app:tint="?android:attr/textColorPrimary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/action_share" />

    </FrameLayout>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/im_detail_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="24dp">

            <!-- Large heading -->
            <TextView
                android:id="@+id/tv_im_detail_heading"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorPrimary"
                android:paddingTop="4dp"
                android:paddingBottom="12dp" />

            <!-- 輸入法資訊 section label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/im_detail_section_info"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="4dp"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="10dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp">

                    <!-- 名稱 row -->
                    <LinearLayout
                        android:id="@+id/row_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/im_detail_label_name"
                            android:textAppearance="?attr/textAppearanceBody2" />

                        <TextView
                            android:id="@+id/tv_im_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="?android:attr/textColorSecondary"
                            android:gravity="end" />

                        <ImageView
                            android:id="@+id/iv_edit_name"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="?android:attr/textColorSecondary"
                            android:contentDescription="@string/im_detail_edit_name_title" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?android:attr/listDivider" />

                    <!-- 版本 row -->
                    <LinearLayout
                        android:id="@+id/row_version"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/im_detail_label_version"
                            android:textAppearance="?attr/textAppearanceBody2" />

                        <TextView
                            android:id="@+id/txtImVersion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="?android:attr/textColorSecondary"
                            android:gravity="end"
                            android:text="-" />

                        <ImageView
                            android:id="@+id/iv_edit_version"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginStart="6dp"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="?android:attr/textColorSecondary"
                            android:contentDescription="@string/im_detail_edit_version_title" />
                    </LinearLayout>

                    <View
                        android:id="@+id/divider_version"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?android:attr/listDivider" />

                    <!-- 筆數 row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/im_detail_label_records"
                            android:textAppearance="?attr/textAppearanceBody2" />

                        <TextView
                            android:id="@+id/tv_im_records"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="2"
                            android:textAppearance="?attr/textAppearanceBody2"
                            android:textColor="?android:attr/textColorSecondary"
                            android:gravity="end"
                            android:text="…" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 軟鍵盤配置 section -->
            <LinearLayout
                android:id="@+id/section_keyboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/im_detail_section_keyboard"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="4dp"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="10dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:id="@+id/row_keyboard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:background="?attr/selectableItemBackground">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/im_detail_label_keyboard"
                        android:textAppearance="?attr/textAppearanceBody2" />

                    <TextView
                        android:id="@+id/tv_keyboard_value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:textAppearance="?attr/textAppearanceBody2"
                        android:textColor="?android:attr/textColorSecondary"
                        android:gravity="end"
                        android:text="@string/im_detail_keyboard_default" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="?android:attr/textColorSecondary"
                        android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 注音鍵盤類型 (phonetic only) -->
            <LinearLayout
                android:id="@+id/section_phonetic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="注音鍵盤類型"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:paddingStart="4dp"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    app:strokeWidth="0dp">

                    <android.widget.Spinner
                        android:id="@+id/spinnerPhoneticType"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:entries="@array/phonetic_keyboard_type" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 字根資料表 section label -->
            <TextView
                android:id="@+id/tv_section_table_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/im_detail_section_table"
                android:textSize="13sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingStart="4dp"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="10dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:id="@+id/row_manage_table"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="14dp"
                    android:paddingBottom="14dp"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginEnd="12dp"
                        android:src="@drawable/ic_grid_on_24"
                        app:tint="@color/material_blue"
                        android:contentDescription="@null" />

                    <TextView
                        android:id="@+id/tv_manage_table_label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/im_detail_manage_table"
                        android:textAppearance="?attr/textAppearanceBody2" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="6dp"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="?android:attr/textColorSecondary"
                        android:contentDescription="@null" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- 字根對應設定 (custom only) -->
            <LinearLayout
                android:id="@+id/section_custom_mapping"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="字根對應設定"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:paddingStart="4dp"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchAcceptNumberIndex"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/accept_number_index"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?android:attr/listDivider" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switchAcceptSymbolIndex"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/accept_symbol_index"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 電話鍵盤設定 (array10 only) -->
            <LinearLayout
                android:id="@+id/section_array10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="電話鍵盤設定"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:paddingStart="4dp"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    app:strokeWidth="0dp">

                    <android.widget.Spinner
                        android:id="@+id/spinnerAutoCommit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:entries="@array/auto_commit_labels" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 選項 section -->
            <LinearLayout
                android:id="@+id/section_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/im_detail_section_options"
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:paddingStart="4dp"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardElevation="0dp"
                    app:cardCornerRadius="10dp"
                    app:strokeWidth="0dp">

                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switch_backup_on_delete"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/im_detail_backup_on_delete"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"
                        android:paddingTop="12dp"
                        android:paddingBottom="12dp" />

                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

            <!-- 移除輸入法 button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_remove_im"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:minHeight="48dp"
                android:text="@string/im_detail_remove_im"
                android:textAllCaps="false"
                android:textColor="@color/setup_status_fg_red"
                android:gravity="center"
                app:backgroundTint="@android:color/transparent"
                app:cornerRadius="4dp"
                app:rippleColor="@color/setup_status_red"
                app:strokeColor="@color/setup_status_fg_red"
                app:strokeWidth="1dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
