<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded surface for the keyboard long-press menu dialog, matching the
     app's preference cards (28dp M3 dialog corners). Background follows the
     system dialog/surface colour so it adapts to light/dark. -->
